# 将本文件复制为 server/.env 后按需填写（不要提交 .env）
# 所有密钥都需要你自己填写，项目不再内置任何凭证。

########## 文本推理（方舟）##########
# 方式 1（推荐）：直接使用方舟 API Key
ARK_API_KEY=

# 方式 2：使用 AK/SK + 推理接入点自动换取临时 Key
VOLC_ACCESSKEY=
VOLC_SECRETKEY=
ARK_ENDPOINT_ID=

# 模型 ID（推荐显式填写；也可直接填 ARK_ENDPOINT_ID）
ARK_MODEL=
# 可选：教练模型；不填则与 ARK_MODEL 一致
ARK_COACH_MODEL=
# true=调用 /responses；false=调用 /chat/completions
ARK_USE_RESPONSES=true
# disabled | enabled | auto
ARK_THINKING=disabled
# 一般无需修改
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

########## 语音对话（OpenSpeech）##########
VOLC_WS_URL=wss://openspeech.bytedance.com/api/v3/realtime/dialogue
VOLC_APP_ID=
VOLC_ACCESS_TOKEN=
VOLC_APP_KEY=
VOLC_RESOURCE_ID=volc.speech.dialog
VOLC_MODEL=2.2.0.0
VOLC_SPEAKER=zh_female_vv_jupiter_bigtts

########## 运行参数 ##########
PORT=8787
# true=规则演示模式（不接大模型）
DEMO_MODE=false
